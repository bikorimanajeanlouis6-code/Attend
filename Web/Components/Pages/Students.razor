@page "/students"

@using Application.Services.StudentServices
@using Application.DTOs
@inject NavigationManager Navigation
@inject IStudentService StudentService
<h1>
    Students 
    <a class="btn btn-primary" href="/students/add">Add Student</a>
</h1>
<table class="table">
 <tr>

    <th>ID</th>
    <th>Name</th>
    <th>Date of Birth</th>
    <th>sex</th>
    <th>email</th>
    <th>phone</th>
    <th>address</th>
    <th>FatherName</th>
    <th>MatherName</th>
    <th>FatherPhone</th>
    <th>MatherPhone</th>
    <th>UserAdded</th>
    <th>DateAdded</th>
    <th>Status</th>
  <th>Details</th>
</tr>
@foreach(var student in students){
    <tr>
        <td>@student.Id</td>
        <td>@student.Name</td>
        <td>@student.DateofBirth</td>
        <td>@student.Sex</td>
        <td>@student.Email</td>
        <td>@student.Phone</td>
        <td>@student.Address</td>
        <td>@student.FatherName</td>
        <td>@student.MatherName</td>
        <td>@student.FatherPhoneNmuber</td>
        <td>@student.MatherPhoneNumber</td>
        <td>@student.RegNumber</td>
        <td>@student.UserAdded</td>
        <td>@student.DateAdded</td>
        <td>@student.Status</td>
        
        <td><a href="/students/@student.Id" class="btn btn-primary" >View Details</a>
       </td>


     
    </tr>
}

</table>
@code
{
     private List<GetStudentDTO> students  = new List<GetStudentDTO>();

   protected override async Task OnInitializedAsync()
        {
            students= await StudentService.GetAllStudentsAsync();

        }


}





