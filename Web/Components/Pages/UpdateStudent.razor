@page "/students/update/{id:int}"
@using Application.DTOs
@using Application.Services.StudentServices
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IStudentService StudentService

<h1>Update Student</h1>
<div>
    <EditForm Model="student" OnValidSubmit="EditStudentAsync">
    
    <div class="form-group">
        <label >Name</label>
         <InputText class="form-control" @bind-Value="student.Name" />
    </div>
    <div class="form-group">
        <label >Date of Birth</label>
        <InputDate class="form-control"  @bind-Value="student.DateofBirth" />
    </div>  
    <div class="form-group">
        <label>sex</label>
        <InputSelect  class="form-control" @bind-Value="student.Sex">
               <option value="">Select Sex</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
        </InputSelect>
    </div>


    <div class="form-group">
        <label >Email</label>
        <InputText class="form-control"  @bind-Value="student.Email"/>
    </div>
    
    <div class="form-group">
        <label >Phone</label>
        <InputText class="form-control" @bind-Value="student.Phone" />
    </div>
    <div class="form-group">
        <label for="address">Address</label>
        <InputText class="form-control" @bind-Value="student.Address" />
    </div>
    <div class="form-group">
        <label >Father's Name</label>
        <InputText class="form-control" @bind-Value="student.FatherName" />
    </div>
    <div class="form-group">
        <label >Mother's Name</label>
        <InputText class="form-control"  @bind-Value="student.MatherName" />
    </div>
    <div class="form-group">
        <label>Father's Phone</label>
        <InputText class="form-control"@bind-Value="student.FatherPhoneNmuber" />
    </div>
    <div class="form-group">
        <label>Mother's Phone</label>
        <InputText class="form-control" @bind-Value="student.MatherPhoneNumber" />
    </div>
    <button type="submit" class="btn btn-primary">Update</button>
    </EditForm>
 </div>   
@code{
    [Parameter]
    public int Id{get;set;}
    private GetStudentDTO? existingstudent;
    private UpdateStudentDTO student = new();
    protected override async Task OnParametersSetAsync()
    {
        existingstudent=   await StudentService.GetStudentByIdAsync(Id);
        if (existingstudent != null)
        {
            student.Id = existingstudent.Id;
            student.Name= existingstudent.Name;
            student.Address= existingstudent.Address;
            student.Sex=existingstudent.Sex;
            student.DateofBirth=existingstudent.DateofBirth;
            student.Email=existingstudent.Email;
            student.MatherName=existingstudent.MatherName;
            student.MatherPhoneNumber=existingstudent.MatherPhoneNumber;
            student.FatherName=existingstudent.FatherName;
            student.FatherPhoneNmuber=existingstudent.FatherPhoneNmuber;
            student.RegNumber=existingstudent.RegNumber;
           }
    }
    private async Task EditStudentAsync()
    {
       await StudentService.UpdateStudentAsync(student);
        Navigation.NavigateTo("/students");
    }

}