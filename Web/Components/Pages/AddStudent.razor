@using Application.Services.StudentServices
@using Application.DTOs;
@using Infrastructure.Migrations
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IStudentService StudentService

@* @page "/students/add" *@


<MudDialog>
    <TitleContent>Add Student</TitleContent>
    <DialogContent>
         <EditForm Model="student" OnValidSubmit="SaveStudentAsync">
           <MudGrid>
            <MudItem xs="6">
                <MudTextField 
                @bind-Value="student.Name"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Label="Fullname"
                Placeholder="Fullname">
                </MudTextField>
            </MudItem>
            <MudItem xs="6">
                <MudSelect 
                T="string"
                @bind-Value="student.Sex"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Placeholder="select sex">
                Label="Sex"
                <MudSelectItem Value="@("Male")">Male</MudSelectItem>
                <MudSelectItem Value="@("Female")">Female</MudSelectItem>

                </MudSelect>
            </MudItem>
            <MudItem xs="6">
                <MudTextField 
                @bind-Value="student.Email"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Label="Email"
                Placeholder="fiston@gmail.com">
                </MudTextField>
            </MudItem>
            <MudItem xs="6">
                <MudTextField 
                @bind-Value="student.Phone"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Label="Phone"
                Placeholder="078 2828 2828">
                </MudTextField>
            </MudItem>
            <MudItem xs="6">
                <MudDatePicker 
                Date="student.DateofBirth"
                DateChanged="date => student.DateofBirth = date ?? default"
                Margin="Margin.Dense"
                DateFormat="yyyy-MM-dd"
                Variant="Variant.Outlined"
                Label="Date of Birth"
                Placeholder="dd/mm/yyyy">
                </MudDatePicker>
            </MudItem>
            <MudItem xs="6">
                <MudTextField 
                @bind-Value="student.Address"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Label="Address"
                Placeholder="Kigali-Rwanda">
                </MudTextField>
            </MudItem>
              <MudItem xs="6">
                <MudTextField 
                @bind-Value="student.MatherName"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Label="Mother's Name"
                Placeholder="MatherName">
                </MudTextField> 
            </MudItem>
             <MudItem xs="6">
                <MudTextField 
                @bind-Value="student.MatherPhoneNumber"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Label="Mother's Phone Number"
                Placeholder="MatherPhoneNumber">
                </MudTextField> 
            </MudItem>
            <MudItem xs="6">
                <MudTextField 
                @bind-Value="student.FatherPhoneNmuber"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Label="Father's Phone Number"
                Placeholder="FatherPhoneNmuber">
                </MudTextField> 
            </MudItem>
            <MudItem xs="6">
                <MudTextField 
                @bind-Value="student.FatherName"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Label="Father's Name"
                Placeholder="FatherName">
                </MudTextField> 
            </MudItem>
            <MudItem xs="6">
                <MudTextField 
                @bind-Value="student.RegNumber"
                Margin="Margin.Dense"
                Variant="Variant.Outlined"
                Label="Registration Number"
                Placeholder="RegNumber">
                </MudTextField> 
            </MudItem>
            <MudItem xs="12">
                <MudButton 
                Variant="Variant.Filled"
                Color="Color.Primary"
                FullWidth="true" 
                ButtonType="ButtonType.Submit">
                SAVE
                </MudButton>
            </MudItem>

           </MudGrid> 
        </EditForm>

    </DialogContent>
    
</MudDialog>


@code{

     [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
    private AddStudentDTO student = new ();
       private async Task SaveStudentAsync()
    {
       await StudentService.AddStudentAsync(student);
       MudDialog.Close(DialogResult.Ok(true));
    }
}