@page "/classes/update/{id:int}"
@using Application.Services.ClassServices
@rendermode InteractiveServer
@using Application.DTOs
@inject NavigationManager Navigation
@inject IClassService ClassService


<div>
    <EditForm OnValidSubmit="EditClassAsync" Model="classs">
      
         <div class="form-group">
            <label>Name</label>
            <InputText @bind-Value="classs.Name" class="form-control" />
            </div>
         <div class="form-group">
         <label for="name">Name</label>
        <InputText class="form-control" id="name" @bind-Value="classs.Name" />
         </div>

        <div class="form-group">
            <label for="educationLevel">Education Level</label>
            <InputNumber class="form-control" id="educationLevel" @bind-Value="classs.EducationLevelId" />
            </div>

            <div class="form-group">
                <label for="faculty">Faculty</label>
                <InputNumber class="form-control" id="faculty" @bind-Value="classs.FacultyId" />
        </div>
<button type="submit" class="btn btn-primary">Update</button>        
    </EditForm>
</div>

@code{
    [Parameter]
    public int Id{get;set;}
    private GetClassDTO? existingclass;
    private UpdateClassDTO classs = new();
    protected override async Task OnParametersSetAsync()
    {
        existingclass= await ClassService.GetClassByIdAsync(Id);
        if (existingclass != null)
        {
            classs.Id = existingclass.Id;
            classs.Name= existingclass.Name;
            classs.EducationLevelId= existingclass.EducationLevelId;
            classs.FacultyId= existingclass.FacultyId;
        }
    }
    private async Task EditClassAsync()
    {
        await ClassService.UpdateClassAsync(classs);
        Navigation.NavigateTo("/classes");
    }

}