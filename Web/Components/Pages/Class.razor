@page "/class"
@using Application.Services.ClassServices
@using Domain.Entities;

@inject IClassService ClassService
<h1>
    Class List
</h1>
<table>
    <tr>
        <th>Class ID</th>
        <th>Class Name</th>
        <th>Class EducationLevel</th>
        <th>Class Faculty</th>
    </tr>

@foreach(var cls in classes){
    <tr>
        <td>@cls.Id</td>
        <td>@cls.Name</td>
        <td>@cls.EducationLevelId</td>
        <td>@cls.Faculty</td>
    </tr>

}
</table>

@code
{
   
    private List<Classs> classes = new List<Classs>();
        protected override void OnInitialized()
    {
        classes= ClassService.GetAllClasses();
    }
}